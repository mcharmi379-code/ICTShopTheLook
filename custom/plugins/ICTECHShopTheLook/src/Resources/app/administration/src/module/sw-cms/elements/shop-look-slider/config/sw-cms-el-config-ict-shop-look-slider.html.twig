<div class="sw-cms-el-config-ict-shop-look-slider">
    <sw-tabs
        default-item="content"
    >
        <template #default="{ active }">
            <sw-tabs-item
                :title="$t('sw-cms.elements.general.config.tab.content')"
                name="content"
                :active-tab="active"
            >
                {{ $t('sw-cms.elements.general.config.tab.content') }}
            </sw-tabs-item>
            <sw-tabs-item
                :title="$t('sw-cms.elements.general.config.tab.settings')"
                name="settings"
                :active-tab="active"
            >
                {{ $t('sw-cms.elements.general.config.tab.settings') }}
            </sw-tabs-item>
        </template>

        <template #content="{ active }">
            <div v-if="active === 'content'">
                <sw-upload-listener
                    :upload-tag="uploadTag"
                    auto-upload
                    @media-upload-finish="onImageUpload"
                />

                <sw-media-list-selection-v2
                    :entity-media-items="mediaItems"
                    :entity="entity"
                    :upload-tag="uploadTag"
                    :default-folder-name="defaultFolderName"
                    @upload-finish="onImageUpload"
                    @item-remove="onItemRemove"
                    @open-sidebar="onOpenMediaModal"
                    @item-sort="onItemSort"
                />
            </div>

            <div v-if="active === 'settings'">
                <sw-text-field
                    v-model:value="element.config.heading.value"
                    :label="$tc('ict-shop-look-slider.config.heading.label')"
                    :help-text="$tc('ict-shop-look-slider.config.heading.helpText')"
                    @update:value="emitUpdateEl"
                />

                <sw-single-select
                    v-model:value="element.config.navigationArrows.value"
                    :label="$tc('sw-cms.elements.imageSlider.config.label.navigationArrows')"
                    help-text="Choose where the previous/next arrows appear: inside the slider, outside, or hidden."
                    :options="navigationArrowsValueOptions"
                    label-property="label"
                    value-property="value"
                    @update:value="emitUpdateEl"
                />

                <sw-single-select
                    v-model:value="element.config.navigationDots.value"
                    :label="$tc('sw-cms.elements.imageSlider.config.label.navigationDots')"
                    help-text="Choose where the dot indicators appear: inside the slider, outside, or hidden."
                    :options="navigationDotsValueOptions"
                    label-property="label"
                    value-property="value"
                    @update:value="emitUpdateEl"
                />

                <sw-number-field
                    v-model:value="element.config.speed.value"
                    :label="$tc('sw-cms.elements.general.config.label.speed')"
                    help-text="Transition speed between slides in milliseconds (e.g. 300 = 0.3 seconds)."
                    number-type="int"
                    :min="0"
                    :max="3600000"
                    @update:value="emitUpdateEl"
                />

                <sw-switch-field
                    v-model:value="element.config.autoSlide.value"
                    :label="$tc('sw-cms.elements.general.config.label.autoSlide')"
                    help-text="When enabled, the slider advances automatically without user interaction."
                    @update:value="onChangeAutoSlide"
                />

                <sw-number-field
                    v-model:value="element.config.autoplayTimeout.value"
                    :label="$tc('sw-cms.elements.general.config.label.autoplayTimeout')"
                    help-text="Time in milliseconds each slide is shown before advancing automatically (requires Auto Slide to be enabled)."
                    number-type="int"
                    :min="0"
                    :max="3600000"
                    @update:value="emitUpdateEl"
                />

                {# <sw-entity-single-select
                    v-model:value="element.config.navigationCategoryId.value"
                    entity="category"
                    :criteria="categoryCriteria"
                    :label="$t('ict-shop-look-slider.config.navigationCategory.label')"
                    :help-text="$t('ict-shop-look-slider.config.navigationCategory.helpText')"
                    :placeholder="$t('ict-shop-look-slider.config.navigationCategory.placeholder')"
                    show-clearable-button
                    @update:value="emitUpdateEl"
                /> #}

                <div
                    v-for="(sliderItem, index) in items"
                    :key="index"
                    style="margin-top:20px;padding:15px;border:1px solid #ddd;"
                >
                    <img
                        v-if="sliderItem.mediaUrl"
                        :src="sliderItem.mediaUrl"
                        style="width:60px;height:60px;object-fit:cover;margin-bottom:10px;"
                    >

                    <sw-single-select
                        :value="sliderItem.linkType || 'shopPage'"
                        :label="$tc('ict-shop-look-slider.config.linkType.label')"
                        :help-text="$tc('ict-shop-look-slider.config.linkType.helpText')"
                        :options="linkTypeOptions"
                        label-property="label"
                        value-property="value"
                        @update:value="onLinkTypeChange(index, $event)"
                    />

                    <sw-cms-page-select
                        v-if="(sliderItem.linkType || 'shopPage') === 'shopPage'"
                        :value="sliderItem.cmsPageId"
                        page-type="page"
                        :label="$tc('ict-shop-look-slider.config.shopPage.label')"
                        :help-text="$tc('ict-shop-look-slider.config.shopPage.helpText')"
                        :placeholder="$tc('ict-shop-look-slider.config.shopPage.placeholder')"
                        @update:value="onCmsPageChange(index, $event)"
                    />

                    <sw-single-select
                        v-if="(sliderItem.linkType || 'shopPage') === 'entity'"
                        :value="sliderItem.url"
                        :label="$tc('ict-shop-look-slider.config.entityLink.label')"
                        :help-text="$tc('ict-shop-look-slider.config.entityLink.helpText')"
                        :options="seoUrlOptions"
                        :placeholder="$tc('ict-shop-look-slider.config.entityLink.placeholder')"
                        label-property="label"
                        value-property="value"
                        @update:value="onUrlChange(index, $event)"
                    />

                    <sw-text-field
                        v-if="(sliderItem.linkType || 'shopPage') === 'custom'"
                        :value="sliderItem.customUrl"
                        :label="$tc('ict-shop-look-slider.config.customUrl.label')"
                        :help-text="$tc('ict-shop-look-slider.config.customUrl.helpText')"
                        :placeholder="$tc('ict-shop-look-slider.config.customUrl.placeholder')"
                        @update:value="onCustomUrlChange(index, $event)"
                    />

                    <div v-if="(sliderItem.linkType || 'shopPage') === 'entity' && sliderItem.url" style="margin-top:4px;padding:4px 8px;background:#f5f5f5;border-radius:3px;word-break:break-all;">
                        <small style="color:#555;">{{ sliderItem.url }}</small>
                    </div>

                    <div v-if="(sliderItem.linkType || 'shopPage') === 'custom' && sliderItem.customUrl" style="margin-top:4px;padding:4px 8px;background:#f5f5f5;border-radius:3px;word-break:break-all;">
                        <small style="color:#555;">{{ sliderItem.customUrl }}</small>
                    </div>

                    <sw-switch-field
                        v-model:value="sliderItem.newTab"
                        :label="$tc('sw-cms.elements.image.config.label.linkNewTab')"
                        help-text="When enabled, the link opens in a new browser tab."
                    />
                </div>
            </div>
        </template>
    </sw-tabs>

    <sw-media-modal-v2
        v-if="mediaModalIsOpen"
        variant="full"
        :caption="$t('sw-cms.elements.general.config.caption.mediaUpload')"
        :entity-context="cmsPageState.entityName"
        :initial-folder-id="cmsPageState.defaultMediaFolderId"
        @media-upload-remove-image="onItemRemove"
        @media-modal-selection-change="onMediaSelectionChange"
        @modal-close="onCloseMediaModal"
    />
</div>
