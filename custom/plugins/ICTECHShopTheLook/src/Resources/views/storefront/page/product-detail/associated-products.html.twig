{% set shopTheLookData = page.getExtension('shopTheLookProducts') %}

{# If no data from subscriber, try to get it directly using Twig extension #}
{% if not shopTheLookData %}
    {% set currentProduct = page.product %}
    {% set currentProductId = currentProduct.id %}
    {% set currentParentId = currentProduct.parentId %}
    
    {# {{ dump('Fallback: Getting data for product:', currentProductId, 'parent:', currentParentId) }} #}
    
    {# Get Shop The Look data using Twig extension #}
    {# {% set relatedProducts = getShopTheLookDataForProduct(currentProductId, currentParentId, context) %} #}
    
    {# {{ dump('Fallback: Got related products:', relatedProducts|length) }} #}
    
    {% if relatedProducts %}
        {# Create a mock struct-like object #}
        {% set shopTheLookData = { 'relatedLooks': relatedProducts } %}
    {% endif %}
{% endif %}

{# {{ dump('Final shopTheLookData:', shopTheLookData) }} #}

{% if shopTheLookData and (shopTheLookData.relatedLooks or shopTheLookData.relatedLooks is defined) %}
<div class="shop-the-look-associated-products">
    <h3 class="h4 mb-3">Complete The Look</h3>
    
    <div class="table-responsive">
        <table class="table table-striped table-hover">
            <thead class="thead-light">
                <tr>
                    <th scope="col">Image</th>
                    <th scope="col">Product</th>
                    <th scope="col">Variants</th>
                    <th scope="col">Price</th>
                    <th scope="col">Action</th>
                </tr>
            </thead>
            <tbody>
                {% for product in (shopTheLookData.relatedLooks ?? shopTheLookData.relatedLooks) %}
                        <tr class="product-row" data-product-id="{{ product.id }}">
                            <td>
                                {% if product.cover and product.cover.media %}
                                    <img src="{{ product.cover.media.url }}" 
                                         alt="{{ product.name }}" 
                                         class="img-fluid rounded"
                                         style="max-width: 60px; max-height: 60px; object-fit: cover;">
                                {% else %}
                                    <div class="bg-light rounded d-flex align-items-center justify-content-center" 
                                         style="width: 60px; height: 60px;">
                                        <i class="fas fa-image text-muted"></i>
                                    </div>
                                {% endif %}
                            </td>
                            <td>
                                <div class="product-info">
                                    <strong class="d-block">{{ product.name }}</strong>
                                    <small class="text-muted">{{ product.productNumber }}</small>
                                </div>
                            </td>
                            <td>
                                {% if product.hasVariants and product.variants %}
                                    <select class="form-control form-select variant-selector" 
                                            data-product-id="{{ product.id }}"
                                            onchange="updateSelectedVariant('{{ product.id }}', this.value)">
                                        <option value="">Select Variant</option>
                                        {% for variant in product.variants %}
                                            <option value="{{ variant.id }}" 
                                                    data-price="{{ variant.price.first.gross }}"
                                                    data-stock="{{ variant.stock }}">
                                                {% for option in variant.options %}
                                                    {{ option.option }}{% if not loop.last %}, {% endif %}
                                                {% endfor %}
                                                ({{ variant.price.first.gross|currency }})
                                            </option>
                                        {% endfor %}
                                    </select>
                                {% else %}
                                    <span class="text-muted">No Variants</span>
                                {% endif %}
                            </td>
                            <td>
                                <span class="price-display fw-bold text-success" 
                                      id="price-{{ product.id }}"
                                      data-base-price="{{ product.price.first.gross }}">
                                    {{ product.price.first.gross|currency }}
                                </span>
                            </td>
                            <td>
                                <form action="{{ path('frontend.checkout.line-item.add') }}" method="post" class="add-to-cart-form" data-add-to-cart="true">
                                    {% if product.hasVariants and product.variants %}
                                        <input type="hidden" name="lineItems[{{ product.id }}][id]" value="" id="variant-id-{{ product.id }}" required>
                                        <input type="hidden" name="lineItems[{{ product.id }}][type]" value="product">
                                        <input type="hidden" name="lineItems[{{ product.id }}][quantity]" value="1">
                                        <button type="submit" class="btn btn-primary btn-sm add-to-cart-btn" disabled 
                                                id="add-to-cart-{{ product.id }}">
                                            Add to Cart
                                        </button>
                                    {% else %}
                                        <input type="hidden" name="lineItems[{{ product.id }}][id]" value="{{ product.id }}">
                                        <input type="hidden" name="lineItems[{{ product.id }}][type]" value="product">
                                        <input type="hidden" name="lineItems[{{ product.id }}][quantity]" value="1">
                                        <button type="submit" class="btn btn-primary btn-sm add-to-cart-btn">
                                            Add to Cart
                                        </button>
                                    {% endif %}
                                </form>
                            </td>
                        </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

<style>
.shop-the-look-associated-products {
    margin: 2rem 0;
    padding: 1.5rem;
    border: 1px solid #dee2e6;
    border-radius: 0.5rem;
    background-color: #f8f9fa;
}

.product-info {
    line-height: 1.4;
}

.variant-selector {
    min-width: 200px;
}

.add-to-cart-btn:disabled {
    opacity: 0.6;
    cursor: not-allowed;
}

.table th {
    border-top: none;
    font-weight: 600;
    color: #495057;
}
</style>

<script>
function updateSelectedVariant(productId, variantId) {
    const variantInput = document.getElementById('variant-id-' + productId);
    const addToCartBtn = document.getElementById('add-to-cart-' + productId);
    const priceDisplay = document.getElementById('price-' + productId);
    
    if (variantInput) {
        variantInput.value = variantId;
    }
    
    if (addToCartBtn) {
        addToCartBtn.disabled = !variantId;
    }
    
    // Update price display
    if (variantId && priceDisplay) {
        const select = document.querySelector(`[data-product-id="${productId}"]`);
        const selectedOption = select.querySelector(`option[value="${variantId}"]`);
        if (selectedOption) {
            const newPrice = selectedOption.dataset.price;
            priceDisplay.textContent = newPrice ? '€' + parseFloat(newPrice).toFixed(2) : priceDisplay.dataset.basePrice ? '€' + parseFloat(priceDisplay.dataset.basePrice).toFixed(2) : '';
        }
    }
}
</script>
{% endif %}