{% block element_ict_shop_look_slider %}

{% set sliderConfig = {
    navigationArrows: element.config.navigationArrows.value,
    navigationDots: element.config.navigationDots.value,
    speed: element.config.speed.value,
    autoSlide: element.config.autoSlide.value,
    autoplayTimeout: element.config.autoplayTimeout.value
} %}

{# {% set sliderItems = element.data.sliderItems ?? element.config.sliderItems.value ?? [] %} #}
{% set sliderItems = element.data.sliderItems ?? [] %}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/tiny-slider/2.9.4/tiny-slider.css">

<div class="ict-shop-look-slider" data-shop-look-slider-options='{{ sliderConfig|json_encode }}'>

    <div class="ict-slider-container">
    {# {{dump("hsdds",sliderItems)}} #}
        {% if sliderItems is not empty %}

        {% for item in sliderItems %}
            {% if item.media and item.media.url %}
                <div class="ict-slide">

                    {% if item.url %}
                        <a href="{{ item.url }}" {% if item.newTab %}target="_blank" rel="noopener"{% endif %}>
                    {% endif %}

                    <img src="{{ item.media.url }}" alt="">

                    {% if item.url %}
                        </a>
                    {% endif %}

                </div>
            {% endif %}
        {% endfor %}

        {% else %}

            {# Default images if none configured #}
            {% for i in 1..6 %}
                <div class="ict-slide">
                  <img src="{{ asset('bundles/administration/administration/static/img/cms/preview_mountain_large.webp') }}" alt="">
                </div>
            {% endfor %}

        {% endif %}

    </div>

</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/tiny-slider/2.9.4/min/tiny-slider.js"></script>

<script>
window.addEventListener('load', function () {
    var sliders = document.querySelectorAll('.ict-slider-container');
    sliders.forEach(function(container) {
        if (container.children.length > 0) {
            var options = {{ sliderConfig|json_encode|raw }};
            tns({
                container: container,
                items: 6,
                slideBy: 1,
                gutter: 20,
                controls: options.navigationArrows !== 'none',
                controlsPosition: options.navigationArrows === 'outside' ? 'bottom' : 'top',
                controlsText: ['<svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor"><path d="M12.707 5.293a1 1 0 010 1.414L9.414 10l3.293 3.293a1 1 0 01-1.414 1.414l-4-4a1 1 0 010-1.414l4-4a1 1 0 011.414 0z"/></svg>', '<svg width="20" height="20" viewBox="0 0 20 20" fill="currentColor"><path d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z"/></svg>'],
                nav: options.navigationDots !== 'none',
                navPosition: options.navigationDots === 'outside' ? 'bottom' : 'top',
                mouseDrag: true,
                speed: options.speed || 300,
                autoplay: options.autoSlide || false,
                autoplayTimeout: options.autoplayTimeout || 5000,
                autoplayButtonOutput: false,
                responsive: {
                    1200: { items: 6 },
                    992: { items: 4 },
                    768: { items: 3 },
                    480: { items: 2 }
                }
            });
        }
    });
});
</script>

<style>
.ict-slider-container { visibility: hidden; }
.tns-slider { visibility: visible !important; }
.ict-shop-look-slider { padding: 20px 60px; position: relative; }
.ict-slide { padding: 0 10px; }
.ict-slide img { width: 100%; height: auto; display: block; }
.ict-slide a { display: block; }
.tns-controls { position: absolute; top: 50%; transform: translateY(-50%); width: 100%; left: 0; right: 0; pointer-events: none; }
.tns-controls button { position: absolute; background: #007bff; color: white; border: none; padding: 0; cursor: pointer; border-radius: 50%; width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; pointer-events: auto; z-index: 10; }
.tns-controls button:first-child { left: -60px; }
.tns-controls button:last-child { right: -60px; }
.tns-controls button:hover { background: #0056b3; }
.tns-nav { text-align: center; margin-top: 20px; }
.tns-nav button { width: 10px; height: 10px; background: #ccc; border: none; border-radius: 50%; margin: 0 5px; cursor: pointer; }
.tns-nav button.tns-nav-active { background: #007bff; }
</style>

{% endblock %}