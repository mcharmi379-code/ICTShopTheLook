{% block element_ict_shop_the_look %}
    {% set config = element.data %}
    {# {{dump("Config:", config)}} #}

    {% set lookImage = config.lookImage %}
    {% set hotspots = config.hotspots %}
    {% set layoutStyle = config.layoutStyle %}
    <div class="cms-element-ict-shop-the-look">
        <div class="shop-the-look-container">
            
            <!-- Left Side - Main Image with Hotspots -->
            <div class="shop-the-look-image-section">
                {% if lookImage and lookImage.url %}
                    <div class="shop-the-look-main-image" style="position: relative;">
                        <img 
                            src="{{ lookImage.url }}" 
                            alt="Shop The Look"
                            class="main-look-image"
                            {% if config.imageWidth and config.imageHeight %}
                                width="{{ config.imageWidth }}" height="{{ config.imageHeight }}"
                            {% elseif config.imageDimension and config.imageDimension != 'custom' %}
                                {% set dimensions = config.imageDimension|split('x') %}
                                width="{{ dimensions[0] }}" height="{{ dimensions[1] }}"
                            {% elseif config.customWidth and config.customHeight %}
                                width="{{ config.customWidth }}" height="{{ config.customHeight }}"
                            {% endif %}
                        />
                        
                        {% if hotspots %}
                            {% for hotspot in hotspots %}
                                <div 
                                    class="shop-the-look-hotspot"
                                    data-product-id="{{ hotspot.product.id }}"
                                    data-hotspot-index="{{ loop.index0 }}"
                                    style="
                                        position: absolute;
                                        left: {{ hotspot.xPosition }}%;
                                        top: {{ hotspot.yPosition }}%;
                                        width: 16px;
                                        height: 16px;
                                        background: #007bff;
                                        border: 2px solid white;
                                        border-radius: 50%;
                                        transform: translate(-50%, -50%);
                                        cursor: pointer;
                                        box-shadow: 0 2px 8px rgba(0,0,0,0.3);
                                        z-index: 10;
                                    "
                                >
                                    <span class="hotspot-number">{{ loop.index }}</span>
                                    
                                    <!-- Hotspot Popup -->
                                    <div class="hotspot-popup" style="display: none;">
                                        <div class="popup-content">
                                            <div class="popup-image">
                                                {% if hotspot.product.cover %}
                                                    <img src="{{ hotspot.product.cover.media.url }}" alt="{{ hotspot.product.translated.name }}" />
                                                {% endif %}
                                            </div>
                                            <div class="popup-details">
                                                <a href="{{ seoUrl('frontend.detail.page', {'productId': hotspot.product.id}) }}" class="popup-product-link">
                                                    <h4 class="popup-product-name">{{ hotspot.product.translated.name }}</h4>
                                                </a>
                                                {% if hotspot.product.calculatedPrice %}
                                                    <div class="popup-price">{{ hotspot.product.calculatedPrice.unitPrice|currency }}</div>
                                                {% endif %}
                                                <a href="{{ seoUrl('frontend.detail.page', {'productId': hotspot.product.id}) }}" class="popup-view-button">
                                                    View Product
                                                </a>
                                            </div>
                                        </div>
                                        <div class="popup-arrow"></div>
                                    </div>
                                </div>
                            {% endfor %}
                        {% endif %}
                    </div>
                {% endif %}
            </div>
            
            <!-- Right Side - Product List -->
            <div class="shop-the-look-products-section">
                {% if hotspots %}
                    <div class="products-list">
                        {% for hotspot in hotspots %}
                            <div class="product-item" data-product-id="{{ hotspot.product.id }}">
                                
                                <!-- Product Header with Checkbox -->
                                <div class="product-header">
                                    <div class="product-checkbox">
                                        <input 
                                            type="checkbox" 
                                            id="product-{{ hotspot.product.id }}" 
                                            class="product-select-checkbox"
                                            data-product-id="{{ hotspot.product.id }}"
                                            checked
                                        />
                                        <label for="product-{{ hotspot.product.id }}"></label>
                                    </div>
                                    
                                    <div class="product-basic-info">
                                        <div class="product-image">
                                            {% if hotspot.product.cover %}
                                                <img 
                                                    src="{{ hotspot.product.cover.media.url }}" 
                                                    alt="{{ hotspot.product.translated.name }}"
                                                />
                                            {% endif %}
                                        </div>
                                        
                                        <div class="product-details">
                                          <a href="{{ seoUrl('frontend.detail.page', {'productId': hotspot.product.id}) }}" class="popup-product-link">
                                            <h4 class="product-name">{{ hotspot.product.translated.name }}</h4> </a>
                                            
                                            {% if config.showPrices and hotspot.product.calculatedPrice %}
                                                <div class="product-price">
                                                    {{ hotspot.product.calculatedPrice.unitPrice|currency }}
                                                </div>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- Product Variants Section -->
                                {% if config.showVariantSwitch %}
                                    <div class="product-variants">
                                     
                                        
                                        <!-- Show all available variants from allVariants data -->
                                        {% if hotspot.allVariants %}
                                            {% for groupName, options in hotspot.allVariants %}
                                                <div class="variant-group">
                                                    <label class="variant-label">{{ groupName|upper }}</label>
                                                    <div class="variant-options">
                                                        {% for optionId, option in options %}
                                                            <div class="variant-option">
                                                                <input 
                                                                    type="radio" 
                                                                    name="{{ groupName|lower }}-{{ hotspot.product.id }}" 
                                                                    id="{{ groupName|lower }}-{{ option.id }}-{{ hotspot.product.id }}"
                                                                    value="{{ option.id }}"
                                                                    class="variant-radio"
                                                                    data-group="{{ groupName|lower }}"
                                                                    data-product-id="{{ hotspot.product.id }}"
                                                                    data-option-id="{{ option.id }}"
                                                                    data-option-name="{{ option.name }}"
                                                                    {% if loop.first %}checked{% endif %}
                                                                />
                                                                <label for="{{ groupName|lower }}-{{ option.id }}-{{ hotspot.product.id }}" class="variant-label-option">
                                                                    {% if groupName|lower == 'color' or groupName|lower == 'colour' %}
                                                                        <span class="color-swatch" style="background-color: {{ option.colorHexCode ?? '#ccc' }};"></span>
                                                                    {% endif %}
                                                                    {{ option.name }}
                                                                </label>
                                                            </div>
                                                        {% endfor %}
                                                    </div>
                                                </div>
                                            {% endfor %}
                                        {% else %}
                                            <!-- Fallback: Show current product options -->
                                            {% if hotspot.product.options %}
                                                {% set optionGroups = {} %}
                                                {% for option in hotspot.product.options %}
                                                    {% set groupName = option.group.translated.name %}
                                                    {% if optionGroups[groupName] is not defined %}
                                                        {% set optionGroups = optionGroups|merge({(groupName): []}) %}
                                                    {% endif %}
                                                    {% set optionGroups = optionGroups|merge({(groupName): optionGroups[groupName]|merge([option])}) %}
                                                {% endfor %}
                                                
                                                {% for groupName, options in optionGroups %}
                                                    <div class="variant-group">
                                                        <label class="variant-label">{{ groupName|upper }}</label>
                                                        <div class="variant-options">
                                                            {% for option in options %}
                                                                <div class="variant-option">
                                                                    <input 
                                                                        type="radio" 
                                                                        name="{{ groupName|lower }}-{{ hotspot.product.id }}" 
                                                                        id="{{ groupName|lower }}-{{ option.id }}-{{ hotspot.product.id }}"
                                                                        value="{{ option.id }}"
                                                                        class="variant-radio"
                                                                        data-group="{{ groupName|lower }}"
                                                                        data-product-id="{{ hotspot.product.id }}"
                                                                        data-option-id="{{ option.id }}"
                                                                        {% if loop.first %}checked{% endif %}
                                                                    />
                                                                    <label for="{{ groupName|lower }}-{{ option.id }}-{{ hotspot.product.id }}" class="variant-label-option">
                                                                        {% if groupName|lower == 'color' or groupName|lower == 'colour' %}
                                                                            <span class="color-swatch" style="background-color: {{ option.colorHexCode ?? '#ccc' }};"></span>
                                                                        {% endif %}
                                                                        {{ option.translated.name }}
                                                                    </label>
                                                                </div>
                                                            {% endfor %}
                                                        </div>
                                                    </div>
                                                {% endfor %}
                                            {% endif %}
                                            
                                            <!-- Show properties as fallback for products without variants -->
                                            {% if hotspot.product.properties %}
                                                {% set propertyGroups = {} %}
                                                {% for property in hotspot.product.properties %}
                                                    {% set groupName = property.group.translated.name %}
                                                    {% if propertyGroups[groupName] is not defined %}
                                                        {% set propertyGroups = propertyGroups|merge({(groupName): []}) %}
                                                    {% endif %}
                                                    {% set propertyGroups = propertyGroups|merge({(groupName): propertyGroups[groupName]|merge([property])}) %}
                                                {% endfor %}
                                                
                                                {% for groupName, properties in propertyGroups %}
                                                    <!-- Check if this group is not already shown in options -->
                                                    {% set groupInOptions = false %}
                                                    {% if hotspot.product.options %}
                                                        {% for option in hotspot.product.options %}
                                                            {% if option.group.translated.name == groupName %}
                                                                {% set groupInOptions = true %}
                                                            {% endif %}
                                                        {% endfor %}
                                                    {% endif %}
                                                    
                                                    {% if not groupInOptions %}
                                                        <div class="variant-group">
                                                            <label class="variant-label">{{ groupName|upper }}</label>
                                                            <div class="variant-options">
                                                                {% for property in properties %}
                                                                    <div class="variant-option">
                                                                        <input 
                                                                            type="radio" 
                                                                            name="property-{{ groupName|lower }}-{{ hotspot.product.id }}" 
                                                                            id="property-{{ property.id }}-{{ hotspot.product.id }}"
                                                                            value="{{ property.id }}"
                                                                            class="variant-radio"
                                                                            data-group="{{ groupName|lower }}"
                                                                            data-product-id="{{ hotspot.product.id }}"
                                                                            data-option-id="{{ property.id }}"
                                                                            {% if loop.first %}checked{% endif %}
                                                                        />
                                                                        <label for="property-{{ property.id }}-{{ hotspot.product.id }}" class="variant-label-option">
                                                                            {% if groupName|lower == 'color' or groupName|lower == 'colour' %}
                                                                                <span class="color-swatch" style="background-color: {{ property.colorHexCode ?? '#ccc' }};"></span>
                                                                            {% endif %}
                                                                            {{ property.translated.name }}
                                                                        </label>
                                                                    </div>
                                                                {% endfor %}
                                                            </div>
                                                        </div>
                                                    {% endif %}
                                                {% endfor %}
                                            {% endif %}
                                        {% endif %}
                                        
                                    </div>
                                {% endif %}
                                


                                
                                <!-- Store variant mapping data for JavaScript (always needed for add-all) -->
                                {% if hotspot.variantMappingData and hotspot.variantMappingData|length > 0 %}
                                    <script type="application/json" class="variant-data" data-product-id="{{ hotspot.product.id }}">
                                    {
                                        "parentId": "{{ hotspot.parentProduct.id }}",
                                        "variants": [
                                            {% for variant in hotspot.variantMappingData %}
                                            {
                                                "id": "{{ variant.id }}",
                                                "name": "{{ variant.name }}",
                                                "options": [
                                                    {% for optionId in variant.options %}
                                                        "{{ optionId }}"{% if not loop.last %},{% endif %}
                                                    {% endfor %}
                                                ]
                                            }{% if not loop.last %},{% endif %}
                                            {% endfor %}
                                        ]
                                    }
                                    </script>
                                {% endif %}

                                <!-- Individual Add to Cart -->
                                {% if config.addSingleProduct %}
                                    <div class="individual-add-to-cart">
                                        <form action="{{ path('frontend.checkout.line-item.add') }}" method="post" class="add-to-cart-form" data-add-to-cart="true">
                                            
                                            <!-- For products with variants, we need to add the specific variant ID, not the parent -->
                                            {% set productToAdd = hotspot.product %}
                                            {% if hotspot.product.childCount > 0 and hotspot.product.children and hotspot.product.children|length > 0 %}
                                                {% set productToAdd = hotspot.product.children.first %}
                                            {% endif %}
                                            
                                            <input type="hidden" name="lineItems[{{ productToAdd.id }}][id]" value="{{ productToAdd.id }}">
                                            <input type="hidden" name="lineItems[{{ productToAdd.id }}][type]" value="product">
                                            <input type="hidden" name="lineItems[{{ productToAdd.id }}][referencedId]" value="{{ productToAdd.id }}">
                                            <input type="hidden" name="lineItems[{{ productToAdd.id }}][quantity]" value="1">
                                            <input type="hidden" name="lineItems[{{ productToAdd.id }}][stackable]" value="1">
                                            <input type="hidden" name="lineItems[{{ productToAdd.id }}][removable]" value="1">
                                            
                                            <!-- Add current product options as default -->
                                            {% if productToAdd.options %}
                                                {% for option in productToAdd.options %}
                                                    <input type="hidden" name="lineItems[{{ productToAdd.id }}][payload][options][{{ option.id }}]" value="{{ option.id }}" class="default-option">
                                                {% endfor %}
                                            {% endif %}
                                            
                                            <!-- Redirect parameters to stay on same page -->
                                            <input type="hidden" name="redirectTo" value="frontend.cms.page">
                                            <input type="hidden" name="redirectParameters" value='{{ {"id": page.cmsPage.id}|json_encode }}'>
                                            
                                            <button type="submit" class="btn btn-outline-primary add-single-to-cart" data-product-id="{{ hotspot.product.id }}" onclick="debugFormData(this)">
                                                Add to Cart
                                            </button>
                                        </form>
                                    </div>
                                {% endif %}
                                
                            </div>
                        {% endfor %}
                    </div>
                    
                    <!-- Add All to Cart Button -->
                    {% if config.addAllToCart and hotspots|length > 1 %}
                        <div class="add-all-section">
                            <form action="{{ path('frontend.checkout.line-item.add') }}" method="post" class="add-all-form" data-add-to-cart="true">
                                {% for hotspot in hotspots %}
                                    <input type="hidden" name="lineItems[{{ hotspot.product.id }}][id]" value="{{ hotspot.product.id }}" class="product-line-item" data-product-id="{{ hotspot.product.id }}">
                                    <input type="hidden" name="lineItems[{{ hotspot.product.id }}][type]" value="product" class="product-line-item" data-product-id="{{ hotspot.product.id }}">
                                    <input type="hidden" name="lineItems[{{ hotspot.product.id }}][referencedId]" value="{{ hotspot.product.id }}" class="product-line-item" data-product-id="{{ hotspot.product.id }}">
                                    <input type="hidden" name="lineItems[{{ hotspot.product.id }}][quantity]" value="1" class="product-line-item" data-product-id="{{ hotspot.product.id }}">
                                    <input type="hidden" name="lineItems[{{ hotspot.product.id }}][stackable]" value="1" class="product-line-item" data-product-id="{{ hotspot.product.id }}">
                                    <input type="hidden" name="lineItems[{{ hotspot.product.id }}][removable]" value="1" class="product-line-item" data-product-id="{{ hotspot.product.id }}">
                                    
                                    <!-- Add default options for each product -->
                                    {% if hotspot.product.options %}
                                        {% for option in hotspot.product.options %}
                                            <input type="hidden" name="lineItems[{{ hotspot.product.id }}][payload][options][{{ option.id }}]" value="{{ option.id }}" class="product-line-item default-option" data-product-id="{{ hotspot.product.id }}">
                                        {% endfor %}
                                    {% endif %}
                                {% endfor %}
                                
                               
                                <input type="hidden" name="redirectTo" value="frontend.cms.page">
                                <input type="hidden" name="redirectParameters" value='{{ {"id": page.cmsPage.id}|json_encode }}'>
                                
                                <button type="submit" class="btn btn-primary btn-lg add-all-to-cart" onclick="rebuildAddAllForm()">
                                    ADD TO CART 
                                </button>
                            </form>
                        </div>
                    {% endif %}
                {% endif %}
            </div>
            
        </div>
    </div>
{% endblock %}

{% block element_ict_shop_the_look_styles %}
    <style>
        .shop-the-look-container {
            display: grid;
            grid-template-columns: 1fr 400px;
            gap: 40px;
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }
        
        .shop-the-look-image-section {
            position: relative;
        }
        
        .main-look-image {
            {% if config.imageWidth and config.imageHeight %}
            width: {{ config.imageWidth }}px;
            height: {{ config.imageHeight }}px;
            {% elseif config.imageDimension and config.imageDimension != 'custom' %}
            {% set dimensions = config.imageDimension|split('x') %}
            width: {{ dimensions[0] }}px;
            height: {{ dimensions[1] }}px;
            {% elseif config.customWidth and config.customHeight %}
            width: {{ config.customWidth }}px;
            height: {{ config.customHeight }}px;
            {% else %}
            width: 100%;
            height: auto;
            {% endif %}
            border-radius: 8px;
            object-fit: cover;
        }
        
        .shop-the-look-hotspot {
            position: relative;
            animation: pulse 2s infinite;
        }
        
        .shop-the-look-hotspot:hover {
            transform: translate(-50%, -50%) scale(1.2) !important;
        }
        
        .shop-the-look-hotspot.active {
            z-index: 1000 !important;
        }
        
        .shop-the-look-hotspot.active .hotspot-popup {
            display: block !important;
        }
        
        .hotspot-popup {
            position: absolute;
            bottom: 25px;
            left: 50%;
            transform: translateX(-50%);
            background: white;
            border-radius: 8px;
            box-shadow: 0 4px 20px rgba(0,0,0,0.15);
            padding: 0;
            width: 250px;
            z-index: 1001;
            overflow: hidden;
            pointer-events: auto;
        }
        
        .popup-content {
            display: flex;
            flex-direction: column;
        }
        
        .popup-image {
            width: 100%;
            height: 120px;
            overflow: hidden;
            background: #f8f9fa;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .popup-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
            object-position: center;
        }
        
        .popup-details {
            padding: 12px;
        }
        
        .popup-product-link {
            text-decoration: none;
            color: inherit;
        }
        
        .popup-product-link:hover {
            text-decoration: none;
        }
        
        .popup-product-link:hover .popup-product-name {
            color: #007bff;
        }
        
        .popup-product-name {
            font-size: 14px;
            font-weight: 600;
            margin: 0 0 8px 0;
            color: #333;
            line-height: 1.3;
            transition: color 0.2s;
        }
        
        .popup-price {
            font-size: 16px;
            font-weight: bold;
            color: #007bff;
            margin-bottom: 12px;
        }
        
        .popup-view-button {
            display: inline-block;
            background: #007bff;
            color: white;
            padding: 8px 16px;
            border-radius: 4px;
            text-decoration: none;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            transition: background 0.2s;
        }
        
        .popup-view-button:hover {
            background: #0056b3;
            color: white;
            text-decoration: none;
        }
        
        .popup-arrow {
            position: absolute;
            bottom: -6px;
            left: 50%;
            transform: translateX(-50%);
            width: 12px;
            height: 12px;
            background: white;
            border-radius: 2px;
            transform: translateX(-50%) rotate(45deg);
            box-shadow: 2px 2px 4px rgba(0,0,0,0.1);
        }
        
        .hotspot-number {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: white;
            font-size: 10px;
            font-weight: bold;
        }
        
        @keyframes pulse {
            0% { box-shadow: 0 0 0 0 rgba(0, 123, 255, 0.7); }
            70% { box-shadow: 0 0 0 10px rgba(0, 123, 255, 0); }
            100% { box-shadow: 0 0 0 0 rgba(0, 123, 255, 0); }
        }
        
        .shop-the-look-products-section {
            background: #f8f9fa;
            border-radius: 8px;
            padding: 20px;
            height: fit-content;
        }
        
        .products-list {
            margin-bottom: 20px;
        }
        
        .product-item {
            background: white;
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 20px;
            border: 1px solid #e9ecef;
        }
        
        .product-header {
            display: flex;
            align-items: flex-start;
            gap: 15px;
            margin-bottom: 15px;
        }
        
        .product-checkbox {
            margin-top: 5px;
        }
        
        .product-checkbox input[type="checkbox"] {
            width: 18px;
            height: 18px;
            accent-color: #007bff;
        }
        
        .product-basic-info {
            display: flex;
            gap: 15px;
            flex: 1;
        }
        
        .product-image img {
            width: 60px;
            height: 60px;
            object-fit: cover;
            border-radius: 4px;
        }
        
        .product-details {
            flex: 1;
        }
        
        .product-name {
            font-size: 14px;
            font-weight: 600;
            margin: 0 0 5px 0;
            color: #007bff;
            text-transform: uppercase;
        }
        
        .product-price {
            font-size: 16px;
            font-weight: bold;
            color: #333;
        }
        
        .product-variants {
            margin-bottom: 15px;
        }
        
        .variant-group {
            margin-bottom: 15px;
        }
        
        .variant-label {
            display: block;
            font-size: 12px;
            font-weight: 600;
            color: #666;
            margin-bottom: 8px;
            text-transform: uppercase;
        }
        
        .variant-options {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }
        
        .variant-option {
            position: relative;
        }
        
        .variant-radio {
            display: none;
        }
        
        .variant-label-option {
            display: flex;
            align-items: center;
            gap: 5px;
            padding: 6px 12px;
            border: 1px solid #ddd;
            border-radius: 20px;
            cursor: pointer;
            font-size: 12px;
            transition: all 0.2s;
        }
        
        .variant-radio:checked + .variant-label-option {
            background: #007bff;
            color: white;
            border-color: #007bff;
        }
        
        .color-swatch {
            width: 16px;
            height: 16px;
            border-radius: 50%;
            border: 1px solid #ddd;
        }
        
        .size-guide {
            margin-bottom: 15px;
        }
        
        .size-guide-link {
            font-size: 12px;
            color: #666;
            text-decoration: underline;
        }
        
        .individual-add-to-cart {
            margin-bottom: 10px;
        }
        
        .add-single-to-cart {
            width: 100%;
            padding: 8px 16px;
            font-size: 12px;
            text-transform: uppercase;
            font-weight: 600;
        }
        
        .add-all-section {
            text-align: center;
            padding-top: 20px;
            border-top: 1px solid #e9ecef;
        }
        
        .add-all-to-cart {
            width: 100%;
            padding: 15px;
            font-size: 16px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        
        /* Mobile Responsive */
        @media (max-width: 768px) {
            .shop-the-look-container {
                grid-template-columns: 1fr;
                gap: 20px;
            }
            
            .shop-the-look-products-section {
                order: -1;
            }
        }
        
        /* Product item disabled state */
        .product-item.disabled {
            opacity: 0.6;
        }
        
        .product-item.disabled .add-single-to-cart {
            opacity: 0.5;
            pointer-events: none;
        }
    </style>
{% endblock %}

{% block element_ict_shop_the_look_scripts %}
    <script>
        // Global function to rebuild form before submission
        function rebuildAddAllForm() {
            alert("Rebuilding Add All Form");
            const addAllForm = document.querySelector('.add-all-form');
            if (!addAllForm) return;
            
            
            // Remove all existing product inputs
            addAllForm.querySelectorAll('.product-line-item, .variant-option').forEach(input => {
                input.remove();
            });
            
            // Get all checked products
            const checkedProducts = document.querySelectorAll('.product-select-checkbox:checked');
            
            checkedProducts.forEach((checkbox, index) => {
                const productId = checkbox.dataset.productId;
                const productItem = checkbox.closest('.product-item');
                
                
                // Get selected options
                const selectedOptions = [];
                productItem.querySelectorAll('.variant-radio:checked').forEach(radio => {
                    if (radio.dataset.productId === productId) {
                        selectedOptions.push(radio.value);
                    }
                });
                
                // Check for variant data
                const variantDataScript = document.querySelector(`.variant-data[data-product-id="${productId}"]`);
                let variantIdToUse = productId;
                
                if (variantDataScript && selectedOptions.length > 0) {
