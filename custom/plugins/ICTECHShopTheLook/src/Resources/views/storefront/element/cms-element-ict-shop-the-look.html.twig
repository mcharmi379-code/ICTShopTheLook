{% block element_ict_shop_the_look %}
    {% set config = element.data %}
    {% set lookImage = config.lookImage %}
    {% set hotspots = config.hotspots %}
    {% set layoutStyle = config.layoutStyle %}
    <div class="cms-element-ict-shop-the-look">
        <div class="shop-the-look-container">
            
            <!-- Left Side - Main Image with Hotspots -->
            <div class="shop-the-look-image-section">
                {% if lookImage and lookImage.url %}
                    <div class="shop-the-look-main-image" style="position: relative;">
                        <img 
                            src="{{ lookImage.url }}" 
                            alt="Shop The Look"
                            class="main-look-image"
                        />
                        
                        {% if hotspots %}
                            {% for hotspot in hotspots %}
                                <div 
                                    class="shop-the-look-hotspot"
                                    data-product-id="{{ hotspot.product.id }}"
                                    data-hotspot-index="{{ loop.index0 }}"
                                    style="
                                        position: absolute;
                                        left: {{ hotspot.xPosition }}%;
                                        top: {{ hotspot.yPosition }}%;
                                        width: 16px;
                                        height: 16px;
                                        background: #007bff;
                                        border: 2px solid white;
                                        border-radius: 50%;
                                        transform: translate(-50%, -50%);
                                        cursor: pointer;
                                        box-shadow: 0 2px 8px rgba(0,0,0,0.3);
                                        z-index: 10;
                                    "
                                >
                                    <span class="hotspot-number">{{ loop.index }}</span>
                                </div>
                            {% endfor %}
                        {% endif %}
                    </div>
                {% endif %}
            </div>
            
            <!-- Right Side - Product List -->
            <div class="shop-the-look-products-section">
                {% if hotspots %}
                    <div class="products-list">
                        {% for hotspot in hotspots %}
                            <div class="product-item" data-product-id="{{ hotspot.product.id }}">
                                
                                <!-- Product Header with Checkbox -->
                                <div class="product-header">
                                    <div class="product-checkbox">
                                        <input 
                                            type="checkbox" 
                                            id="product-{{ hotspot.product.id }}" 
                                            class="product-select-checkbox"
                                            data-product-id="{{ hotspot.product.id }}"
                                            checked
                                        />
                                        <label for="product-{{ hotspot.product.id }}"></label>
                                    </div>
                                    
                                    <div class="product-basic-info">
                                        <div class="product-image">
                                            {% if hotspot.product.cover %}
                                                <img 
                                                    src="{{ hotspot.product.cover.media.url }}" 
                                                    alt="{{ hotspot.product.translated.name }}"
                                                />
                                            {% endif %}
                                        </div>
                                        
                                        <div class="product-details">
                                            <h4 class="product-name">{{ hotspot.product.translated.name }}</h4>
                                            
                                            {% if config.showPrices and hotspot.product.calculatedPrice %}
                                                <div class="product-price">
                                                    {{ hotspot.product.calculatedPrice.unitPrice|currency }}
                                                </div>
                                            {% endif %}
                                        </div>
                                    </div>
                                </div>
                                
                                <!-- Product Variants Section -->
                                {% if config.showVariantSwitch %}
                                    <div class="product-variants">
                                     
                                        
                                        <!-- Show all available variants from allVariants data -->
                                        {% if hotspot.allVariants %}
                                            {% for groupName, options in hotspot.allVariants %}
                                                <div class="variant-group">
                                                    <label class="variant-label">{{ groupName|upper }}</label>
                                                    <div class="variant-options">
                                                        {% for optionId, option in options %}
                                                            <div class="variant-option">
                                                                <input 
                                                                    type="radio" 
                                                                    name="{{ groupName|lower }}-{{ hotspot.product.id }}" 
                                                                    id="{{ groupName|lower }}-{{ option.id }}-{{ hotspot.product.id }}"
                                                                    value="{{ option.id }}"
                                                                    class="variant-radio"
                                                                    data-group="{{ groupName|lower }}"
                                                                    data-product-id="{{ hotspot.product.id }}"
                                                                    data-option-id="{{ option.id }}"
                                                                    data-option-name="{{ option.name }}"
                                                                    {% if loop.first %}checked{% endif %}
                                                                />
                                                                <label for="{{ groupName|lower }}-{{ option.id }}-{{ hotspot.product.id }}" class="variant-label-option">
                                                                    {% if groupName|lower == 'color' or groupName|lower == 'colour' %}
                                                                        <span class="color-swatch" style="background-color: {{ option.colorHexCode ?? '#ccc' }};"></span>
                                                                    {% endif %}
                                                                    {{ option.name }}
                                                                </label>
                                                            </div>
                                                        {% endfor %}
                                                    </div>
                                                </div>
                                            {% endfor %}
                                        {% else %}
                                            <!-- Fallback: Show current product options -->
                                            {% if hotspot.product.options %}
                                                {% set optionGroups = {} %}
                                                {% for option in hotspot.product.options %}
                                                    {% set groupName = option.group.translated.name %}
                                                    {% if optionGroups[groupName] is not defined %}
                                                        {% set optionGroups = optionGroups|merge({(groupName): []}) %}
                                                    {% endif %}
                                                    {% set optionGroups = optionGroups|merge({(groupName): optionGroups[groupName]|merge([option])}) %}
                                                {% endfor %}
                                                
                                                {% for groupName, options in optionGroups %}
                                                    <div class="variant-group">
                                                        <label class="variant-label">{{ groupName|upper }}</label>
                                                        <div class="variant-options">
                                                            {% for option in options %}
                                                                <div class="variant-option">
                                                                    <input 
                                                                        type="radio" 
                                                                        name="{{ groupName|lower }}-{{ hotspot.product.id }}" 
                                                                        id="{{ groupName|lower }}-{{ option.id }}-{{ hotspot.product.id }}"
                                                                        value="{{ option.id }}"
                                                                        class="variant-radio"
                                                                        data-group="{{ groupName|lower }}"
                                                                        data-product-id="{{ hotspot.product.id }}"
                                                                        data-option-id="{{ option.id }}"
                                                                        {% if loop.first %}checked{% endif %}
                                                                    />
                                                                    <label for="{{ groupName|lower }}-{{ option.id }}-{{ hotspot.product.id }}" class="variant-label-option">
                                                                        {% if groupName|lower == 'color' or groupName|lower == 'colour' %}
                                                                            <span class="color-swatch" style="background-color: {{ option.colorHexCode ?? '#ccc' }};"></span>
                                                                        {% endif %}
                                                                        {{ option.translated.name }}
                                                                    </label>
                                                                </div>
                                                            {% endfor %}
                                                        </div>
                                                    </div>
                                                {% endfor %}
                                            {% endif %}
                                            
                                            <!-- Show properties as fallback for products without variants -->
                                            {% if hotspot.product.properties %}
                                                {% set propertyGroups = {} %}
                                                {% for property in hotspot.product.properties %}
                                                    {% set groupName = property.group.translated.name %}
                                                    {% if propertyGroups[groupName] is not defined %}
                                                        {% set propertyGroups = propertyGroups|merge({(groupName): []}) %}
                                                    {% endif %}
                                                    {% set propertyGroups = propertyGroups|merge({(groupName): propertyGroups[groupName]|merge([property])}) %}
                                                {% endfor %}
                                                
                                                {% for groupName, properties in propertyGroups %}
                                                    <!-- Check if this group is not already shown in options -->
                                                    {% set groupInOptions = false %}
                                                    {% if hotspot.product.options %}
                                                        {% for option in hotspot.product.options %}
                                                            {% if option.group.translated.name == groupName %}
                                                                {% set groupInOptions = true %}
                                                            {% endif %}
                                                        {% endfor %}
                                                    {% endif %}
                                                    
                                                    {% if not groupInOptions %}
                                                        <div class="variant-group">
                                                            <label class="variant-label">{{ groupName|upper }}</label>
                                                            <div class="variant-options">
                                                                {% for property in properties %}
                                                                    <div class="variant-option">
                                                                        <input 
                                                                            type="radio" 
                                                                            name="property-{{ groupName|lower }}-{{ hotspot.product.id }}" 
                                                                            id="property-{{ property.id }}-{{ hotspot.product.id }}"
                                                                            value="{{ property.id }}"
                                                                            class="variant-radio"
                                                                            data-group="{{ groupName|lower }}"
                                                                            data-product-id="{{ hotspot.product.id }}"
                                                                            data-option-id="{{ property.id }}"
                                                                            {% if loop.first %}checked{% endif %}
                                                                        />
                                                                        <label for="property-{{ property.id }}-{{ hotspot.product.id }}" class="variant-label-option">
                                                                            {% if groupName|lower == 'color' or groupName|lower == 'colour' %}
                                                                                <span class="color-swatch" style="background-color: {{ property.colorHexCode ?? '#ccc' }};"></span>
                                                                            {% endif %}
                                                                            {{ property.translated.name }}
                                                                        </label>
                                                                    </div>
                                                                {% endfor %}
                                                            </div>
                                                        </div>
                                                    {% endif %}
                                                {% endfor %}
                                            {% endif %}
                                        {% endif %}
                                        
                                    </div>
                                {% endif %}
                                
                                
                                <!-- Individual Add to Cart -->
                                {% if config.addSingleProduct %}
                                    <div class="individual-add-to-cart">
                                        <form action="{{ path('frontend.checkout.line-item.add') }}" method="post" class="add-to-cart-form" data-add-to-cart="true">
                                            
                                            <!-- Store variant mapping data for JavaScript -->
                                            {% if hotspot.variantMappingData and hotspot.variantMappingData|length > 0 %}
                                                <script type="application/json" class="variant-data" data-product-id="{{ hotspot.product.id }}">
                                                {
                                                    "parentId": "{{ hotspot.parentProduct.id }}",
                                                    "variants": [
                                                        {% for variant in hotspot.variantMappingData %}
                                                        {
                                                            "id": "{{ variant.id }}",
                                                            "name": "{{ variant.name }}",
                                                            "options": [
                                                                {% for optionId in variant.options %}
                                                                    "{{ optionId }}"{% if not loop.last %},{% endif %}
                                                                {% endfor %}
                                                            ]
                                                        }{% if not loop.last %},{% endif %}
                                                        {% endfor %}
                                                    ]
                                                }
                                                </script>
                                            {% endif %}
                                            
                                            <!-- For products with variants, we need to add the specific variant ID, not the parent -->
                                            {% set productToAdd = hotspot.product %}
                                            {% if hotspot.product.childCount > 0 and hotspot.product.children and hotspot.product.children|length > 0 %}
                                                {% set productToAdd = hotspot.product.children.first %}
                                            {% endif %}
                                            
                                            <input type="hidden" name="lineItems[{{ productToAdd.id }}][id]" value="{{ productToAdd.id }}">
                                            <input type="hidden" name="lineItems[{{ productToAdd.id }}][type]" value="product">
                                            <input type="hidden" name="lineItems[{{ productToAdd.id }}][referencedId]" value="{{ productToAdd.id }}">
                                            <input type="hidden" name="lineItems[{{ productToAdd.id }}][quantity]" value="1">
                                            <input type="hidden" name="lineItems[{{ productToAdd.id }}][stackable]" value="1">
                                            <input type="hidden" name="lineItems[{{ productToAdd.id }}][removable]" value="1">
                                            
                                            <!-- Add current product options as default -->
                                            {% if productToAdd.options %}
                                                {% for option in productToAdd.options %}
                                                    <input type="hidden" name="lineItems[{{ productToAdd.id }}][payload][options][{{ option.id }}]" value="{{ option.id }}" class="default-option">
                                                {% endfor %}
                                            {% endif %}
                                            
                                            <!-- Redirect parameters to stay on same page -->
                                            <input type="hidden" name="redirectTo" value="frontend.cms.page">
                                            <input type="hidden" name="redirectParameters" value='{{ {"id": page.cmsPage.id}|json_encode }}'>
                                            
                                            <button type="submit" class="btn btn-outline-primary add-single-to-cart" data-product-id="{{ hotspot.product.id }}" onclick="debugFormData(this)">
                                                Add to Cart
                                            </button>
                                        </form>
                                    </div>
                                {% endif %}
                                
                            </div>
                        {% endfor %}
                    </div>
                    
                    <!-- Add All to Cart Button -->
                    {% if config.addAllToCart and hotspots|length > 1 %}
                        <div class="add-all-section">
                            <form action="{{ path('frontend.checkout.line-item.add') }}" method="post" class="add-all-form" data-add-to-cart="true">
                                {% for hotspot in hotspots %}
                                    <input type="hidden" name="lineItems[{{ hotspot.product.id }}][id]" value="{{ hotspot.product.id }}" class="product-line-item" data-product-id="{{ hotspot.product.id }}">
                                    <input type="hidden" name="lineItems[{{ hotspot.product.id }}][type]" value="product" class="product-line-item" data-product-id="{{ hotspot.product.id }}">
                                    <input type="hidden" name="lineItems[{{ hotspot.product.id }}][referencedId]" value="{{ hotspot.product.id }}" class="product-line-item" data-product-id="{{ hotspot.product.id }}">
                                    <input type="hidden" name="lineItems[{{ hotspot.product.id }}][quantity]" value="1" class="product-line-item" data-product-id="{{ hotspot.product.id }}">
                                    <input type="hidden" name="lineItems[{{ hotspot.product.id }}][stackable]" value="1" class="product-line-item" data-product-id="{{ hotspot.product.id }}">
                                    <input type="hidden" name="lineItems[{{ hotspot.product.id }}][removable]" value="1" class="product-line-item" data-product-id="{{ hotspot.product.id }}">
                                    
                                    <!-- Add default options for each product -->
                                    {% if hotspot.product.options %}
                                        {% for option in hotspot.product.options %}
                                            <input type="hidden" name="lineItems[{{ hotspot.product.id }}][payload][options][{{ option.id }}]" value="{{ option.id }}" class="product-line-item default-option" data-product-id="{{ hotspot.product.id }}">
                                        {% endfor %}
                                    {% endif %}
                                {% endfor %}
                                
                                <!-- Redirect parameters to stay on same page -->
                                <input type="hidden" name="redirectTo" value="frontend.cms.page">
                                <input type="hidden" name="redirectParameters" value='{{ {"id": page.cmsPage.id}|json_encode }}'>
                                
                                <button type="submit" class="btn btn-primary btn-lg add-all-to-cart" onclick="debugFormData(this)">
                                    ADD TO CART
                                </button>
                            </form>
                        </div>
                    {% endif %}
                {% endif %}
            </div>
            
        </div>
    </div>
{% endblock %}

{% block element_ict_shop_the_look_styles %}
    <style>
        .shop-the-look-container {
            display: grid;
            grid-template-columns: 1fr 400px;
            gap: 40px;
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
        }
        
        .shop-the-look-image-section {
            position: relative;
        }
        
        .main-look-image {
            width: 100%;
            height: auto;
            border-radius: 8px;
        }
        
        .shop-the-look-hotspot {
            position: relative;
            animation: pulse 2s infinite;
        }
        
        .shop-the-look-hotspot:hover {
            transform: translate(-50%, -50%) scale(1.2) !important;
        }
        
        .hotspot-number {
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            color: white;
            font-size: 10px;
            font-weight: bold;
        }
        
        @keyframes pulse {
            0% { box-shadow: 0 0 0 0 rgba(0, 123, 255, 0.7); }
            70% { box-shadow: 0 0 0 10px rgba(0, 123, 255, 0); }
            100% { box-shadow: 0 0 0 0 rgba(0, 123, 255, 0); }
        }
        
        .shop-the-look-products-section {
            background: #f8f9fa;
            border-radius: 8px;
            padding: 20px;
            height: fit-content;
        }
        
        .products-list {
            margin-bottom: 20px;
        }
        
        .product-item {
            background: white;
            border-radius: 8px;
            padding: 15px;
            margin-bottom: 20px;
            border: 1px solid #e9ecef;
        }
        
        .product-header {
            display: flex;
            align-items: flex-start;
            gap: 15px;
            margin-bottom: 15px;
        }
        
        .product-checkbox {
            margin-top: 5px;
        }
        
        .product-checkbox input[type="checkbox"] {
            width: 18px;
            height: 18px;
            accent-color: #007bff;
        }
        
        .product-basic-info {
            display: flex;
            gap: 15px;
            flex: 1;
        }
        
        .product-image img {
            width: 60px;
            height: 60px;
            object-fit: cover;
            border-radius: 4px;
        }
        
        .product-details {
            flex: 1;
        }
        
        .product-name {
            font-size: 14px;
            font-weight: 600;
            margin: 0 0 5px 0;
            color: #007bff;
            text-transform: uppercase;
        }
        
        .product-price {
            font-size: 16px;
            font-weight: bold;
            color: #333;
        }
        
        .product-variants {
            margin-bottom: 15px;
        }
        
        .variant-group {
            margin-bottom: 15px;
        }
        
        .variant-label {
            display: block;
            font-size: 12px;
            font-weight: 600;
            color: #666;
            margin-bottom: 8px;
            text-transform: uppercase;
        }
        
        .variant-options {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
        }
        
        .variant-option {
            position: relative;
        }
        
        .variant-radio {
            display: none;
        }
        
        .variant-label-option {
            display: flex;
            align-items: center;
            gap: 5px;
            padding: 6px 12px;
            border: 1px solid #ddd;
            border-radius: 20px;
            cursor: pointer;
            font-size: 12px;
            transition: all 0.2s;
        }
        
        .variant-radio:checked + .variant-label-option {
            background: #007bff;
            color: white;
            border-color: #007bff;
        }
        
        .color-swatch {
            width: 16px;
            height: 16px;
            border-radius: 50%;
            border: 1px solid #ddd;
        }
        
        .size-guide {
            margin-bottom: 15px;
        }
        
        .size-guide-link {
            font-size: 12px;
            color: #666;
            text-decoration: underline;
        }
        
        .individual-add-to-cart {
            margin-bottom: 10px;
        }
        
        .add-single-to-cart {
            width: 100%;
            padding: 8px 16px;
            font-size: 12px;
            text-transform: uppercase;
            font-weight: 600;
        }
        
        .add-all-section {
            text-align: center;
            padding-top: 20px;
            border-top: 1px solid #e9ecef;
        }
        
        .add-all-to-cart {
            width: 100%;
            padding: 15px;
            font-size: 16px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        
        /* Mobile Responsive */
        @media (max-width: 768px) {
            .shop-the-look-container {
                grid-template-columns: 1fr;
                gap: 20px;
            }
            
            .shop-the-look-products-section {
                order: -1;
            }
        }
        
        /* Product item disabled state */
        .product-item.disabled {
            opacity: 0.6;
        }
        
        .product-item.disabled .add-single-to-cart {
            opacity: 0.5;
            pointer-events: none;
        }
    </style>
{% endblock %}

{% block element_ict_shop_the_look_scripts %}
    <script>
        // Debug function to show form data before submission
        function debugFormData(button) {
            const form = button.closest('form');
            const formData = new FormData(form);
            console.log('Submitting form for product:', button.dataset.productId);
            console.log('Submitting', formData);
            
            console.log('=== FORM DEBUG INFO ===');
            console.log('Form action:', form.action);
            console.log('Form method:', form.method);
            console.log('Form data:');
            
            for (let [key, value] of formData.entries()) {
                console.log(`  ${key}: ${value}`);
            }
            
            console.log('All form inputs:');
            form.querySelectorAll('input').forEach(input => {
                console.log(`  ${input.name}: ${input.value} (disabled: ${input.disabled})`);
            });
            console.log('=== END DEBUG INFO ===');
        }
        
        document.addEventListener('DOMContentLoaded', function() {
            
            // Product checkbox functionality
            document.querySelectorAll('.product-select-checkbox').forEach(checkbox => {
                checkbox.addEventListener('change', function() {
                    const productItem = this.closest('.product-item');
                    const form = productItem.querySelector('.add-to-cart-form');
                    
                    if (this.checked) {
                        productItem.classList.remove('disabled');
                        if (form) form.style.display = 'block';
                    } else {
                        productItem.classList.add('disabled');
                        if (form) form.style.display = 'none';
                    }
                    updateAddAllButton();
                });
            });
            
            // Hotspot click to highlight product
            document.querySelectorAll('.shop-the-look-hotspot').forEach(hotspot => {
                hotspot.addEventListener('click', function() {
                    const productId = this.dataset.productId;
                    const productItem = document.querySelector(`.product-item[data-product-id="${productId}"]`);
                    
                    // Remove previous highlights
                    document.querySelectorAll('.product-item').forEach(item => {
                        item.classList.remove('highlighted');
                    });
                    
                    // Highlight clicked product
                    if (productItem) {
                        productItem.classList.add('highlighted');
                        productItem.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
                    }
                });
            });
            
            // Handle variant selection for individual forms
            document.querySelectorAll('.variant-radio').forEach(radio => {
                radio.addEventListener('change', function() {
                    const productId = this.dataset.productId;
                    const form = this.closest('.product-item').querySelector('.add-to-cart-form');
                    
                    if (!productId || !form) {
                        console.error('Missing productId or form');
                        return;
                    }
                    
                    console.log('Variant selection changed for product:', productId);
                    
                    // Get variant data for this product
                    const variantDataScript = document.querySelector(`.variant-data[data-product-id="${productId}"]`);
                    
                    if (variantDataScript) {
                        // This product has variants - find the correct one
                        const variantData = JSON.parse(variantDataScript.textContent);
                        const productItem = this.closest('.product-item');
                        const selectedOptions = [];
                        
                        // Collect all selected options for this product
                        productItem.querySelectorAll('.variant-radio:checked').forEach(selectedRadio => {
                            if (selectedRadio.dataset.productId === productId) {
                                selectedOptions.push(selectedRadio.value);
                            }
                        });
                        
                        console.log('Selected options for product', productId, ':', selectedOptions);
                        
                        // Find the variant that matches all selected options
                        let matchingVariant = findMatchingVariant(variantData.variants, selectedOptions);
                        
                        if (matchingVariant) {
                            console.log('Found matching variant:', matchingVariant);
                            updateFormForVariant(form, matchingVariant.id, selectedOptions);
                        } else {
                            console.warn('No exact match found, using best match or first variant');
                            // Fallback: find variant with most matching options
                            let bestMatch = findBestMatchingVariant(variantData.variants, selectedOptions);
                            if (bestMatch) {
                                updateFormForVariant(form, bestMatch.id, selectedOptions);
                            } else if (variantData.variants.length > 0) {
                                // Last resort: use first variant
                                updateFormForVariant(form, variantData.variants[0].id, selectedOptions);
                            }
                        }
                    } else {
                        // This product doesn't have variants - just update options
                        const selectedOptions = [];
                        const productItem = this.closest('.product-item');
                        productItem.querySelectorAll('.variant-radio:checked').forEach(selectedRadio => {
                            if (selectedRadio.dataset.productId === productId) {
                                selectedOptions.push(selectedRadio.value);
                            }
                        });
                        
                        console.log('Updating simple product options:', selectedOptions);
                        updateFormForVariant(form, productId, selectedOptions);
                    }
                });
            });
            
            function findMatchingVariant(variants, selectedOptions) {
                return variants.find(variant => {
                    // Check if this variant has all the selected options
                    const hasAllOptions = selectedOptions.every(optionId => 
                        variant.options.includes(optionId)
                    );
                    // And check if the variant doesn't have extra options
                    const noExtraOptions = variant.options.length === selectedOptions.length;
                    
                    return hasAllOptions && noExtraOptions;
                });
            }
            
            function findBestMatchingVariant(variants, selectedOptions) {
                let bestMatch = null;
                let maxMatches = 0;
                
                variants.forEach(variant => {
                    const matches = selectedOptions.filter(optionId => 
                        variant.options.includes(optionId)
                    ).length;
                    
                    if (matches > maxMatches) {
                        maxMatches = matches;
                        bestMatch = variant;
                    }
                });
                
                return bestMatch;
            }
            
            function updateFormForVariant(form, variantId, selectedOptions) {
                console.log('Updating form for variant:', variantId, 'with options:', selectedOptions);
                
                // Update all form inputs to use the correct variant ID
                form.querySelectorAll('input[name*="lineItems["]').forEach(input => {
                    const name = input.name;
                    // Replace the product ID in the input name
                    const newName = name.replace(/lineItems\[[^\]]+\]/, `lineItems[${variantId}]`);
                    input.name = newName;
                    
                    // Update value for id and referencedId inputs
                    if (name.includes('[id]') || name.includes('[referencedId]')) {
                        input.value = variantId;
                    }
                });
                
                // Remove existing variant option inputs
                form.querySelectorAll('input.variant-option, input.default-option').forEach(input => {
                    input.remove();
                });
                
                // Add new option inputs for selected variants
                selectedOptions.forEach(optionId => {
                    const optionInput = document.createElement('input');
                    optionInput.type = 'hidden';
                    optionInput.name = `lineItems[${variantId}][payload][options][${optionId}]`;
                    optionInput.value = optionId;
                    optionInput.classList.add('variant-option');
                    form.appendChild(optionInput);
                });
                
                console.log('Form updated successfully');
            }
            
            function updateAddAllButton() {
                const checkedProducts = document.querySelectorAll('.product-select-checkbox:checked').length;
                const addAllButton = document.querySelector('.add-all-to-cart');
                const addAllForm = document.querySelector('.add-all-form');
                
                if (addAllButton && addAllForm) {
                    if (checkedProducts === 0) {
                        addAllButton.disabled = true;
                        addAllButton.textContent = 'SELECT PRODUCTS';
                    } else {
                        addAllButton.disabled = false;
                        addAllButton.textContent = `ADD ${checkedProducts} TO CART`;
                        
                        // Disable inputs for unchecked products
                        const uncheckedProducts = document.querySelectorAll('.product-select-checkbox:not(:checked)');
                        uncheckedProducts.forEach(checkbox => {
                            const productId = checkbox.dataset.productId;
                            addAllForm.querySelectorAll(`.product-line-item[data-product-id="${productId}"]`).forEach(input => {
                                input.disabled = true;
                            });
                        });
                        
                        // Enable inputs for checked products
                        const checkedProductsInputs = document.querySelectorAll('.product-select-checkbox:checked');
                        checkedProductsInputs.forEach(checkbox => {
                            const productId = checkbox.dataset.productId;
                            addAllForm.querySelectorAll(`.product-line-item[data-product-id="${productId}"]`).forEach(input => {
                                input.disabled = false;
                            });
                        });
                    }
                }
            }
            
            // Initialize forms with correct variant data on page load
            document.querySelectorAll('.product-item').forEach(productItem => {
                const form = productItem.querySelector('.add-to-cart-form');
                const productId = productItem.dataset.productId;
                
                if (form && productId) {
                    // Trigger variant selection for initially checked options
                    const checkedRadios = productItem.querySelectorAll('.variant-radio:checked');
                    if (checkedRadios.length > 0) {
                        // Trigger change event on first checked radio to initialize form
                        checkedRadios[0].dispatchEvent(new Event('change'));
                    }
                }
            });
            
            // Initialize
            updateAddAllButton();
        });
    </script>
{% endblock %}