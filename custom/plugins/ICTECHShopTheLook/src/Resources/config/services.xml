<?xml version="1.0" ?>
<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services https://symfony.com/schema/dic/services/services-1.0.xsd">
    <services>
        <!-- CMS Element Resolver -->
        <service id="ICTECHShopTheLook\Core\Content\Cms\ShopTheLookCmsElementResolver">
            <argument type="service" id="sales_channel.product.repository"/>
            <tag name="shopware.cms.data_resolver"/>
        </service>
        
        <!-- Slider CMS Element Resolver -->
        <service id="ICTECHShopTheLook\Core\Content\Cms\SalesChannel\IctShopLookSliderCmsElementResolver">
            <tag name="shopware.cms.data_resolver"/>
        </service>
        
        <!-- Product Detail Page Subscriber -->
        <service id="ICTECHShopTheLook\Subscriber\ProductDetailPageSubscriber">
            <argument type="service" id="cms_slot.repository"/>
            <argument type="service" id="product.repository"/>
            <argument type="service" id="ICTECHShopTheLook\Service\ShopTheLookService"/>
            <tag name="kernel.event_subscriber"/>
        </service>
        
        <!-- Debug Shop The Look Command -->
        <service id="ICTECHShopTheLook\Command\DebugShopTheLookCommand">
            <argument type="service" id="cms_slot.repository"/>
            <argument type="service" id="product.repository"/>
            <tag name="console.command"/>
        </service>
        
        <!-- Twig Extension -->
        <service id="ICTECHShopTheLook\Twig\ShopTheLookExtension">
            <argument type="service" id="cms_slot.repository"/>
            <argument type="service" id="product.repository"/>
            <tag name="twig.extension"/>
        </service>
        
        <!-- Shop The Look Service -->
        <service id="ICTECHShopTheLook\Service\ShopTheLookService">
            <argument type="service" id="cms_slot.repository"/>
            <argument type="service" id="product.repository"/>
        </service>
    </services>
</container>
