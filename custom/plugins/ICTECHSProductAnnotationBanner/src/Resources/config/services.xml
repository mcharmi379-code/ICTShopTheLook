<?xml version="1.0" ?>

<container xmlns="http://symfony.com/schema/dic/services"
           xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
           xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd">

    <services>

        <service id="ICTECHSProductAnnotationBanner\Core\Content\ProductAnnotationBanner\ProductAnnotationBannerDefinition">
            <tag name="shopware.entity.definition" entity="product_annotation_banner"/>
        </service>

        <service
                id="ICTECHSProductAnnotationBanner\Core\Content\ProductAnnotationBanner\Aggregate\ProductAnnotationBannerAxis\ProductAnnotationBannerAxisDefinition">
            <tag name="shopware.entity.definition" entity="product_annotation_banner_axis"/>
        </service>

        <service id="ICTECHSProductAnnotationBanner\Core\Content\Extension\MediaExtension">
            <tag name="shopware.entity.extension"/>
        </service>

        <service id="ICTECHSProductAnnotationBanner\Core\Content\Extension\CategoryExtension">
            <tag name="shopware.entity.extension"/>
        </service>

        <service id="ICTECHSProductAnnotationBanner\Core\Content\Extension\ManufacturerExtension">
            <tag name="shopware.entity.extension"/>
        </service>

        <service id="ICTECHSProductAnnotationBanner\Core\Content\AnnotationBannerImage\Cms\AnnotationBannerImageCmsElementResolver">
            <tag name="shopware.cms.data_resolver"/>
            <argument type="service" id="Shopware\Core\Framework\Util\HtmlSanitizer"/>
            <argument type="service" id="Shopware\Core\System\SystemConfig\SystemConfigService"/>
            <argument type="service" id="product.repository"/>
            <argument type="service" id="category.repository"/>
            <argument type="service" id="product_annotation_banner.repository"/>
            <argument type="service" id="product_annotation_banner_axis.repository"/>
        </service>

        <service id="ICTECHSProductAnnotationBanner\Service\ScheduledTask\CacheClearTask" public="true">
            <tag name="shopware.scheduled.task" />
        </service>

        <service id="ICTECHSProductAnnotationBanner\Service\ScheduledTask\CacheClearTaskHandler">
            <argument type="service" id="scheduled_task.repository"/>
            <argument type="service" id="product.repository"/>
            <argument type="service" id="category.repository"/>
            <argument type="service" id="product_manufacturer.repository"/>
            <argument type="service" id="product_annotation_banner_axis.repository"/>
            <argument type="service" id="service_container"/>
             <tag name="messenger.message_handler" />
        </service>

    </services>
</container>