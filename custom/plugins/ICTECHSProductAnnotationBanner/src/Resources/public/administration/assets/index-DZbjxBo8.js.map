{% block sw_cms_block_annotationBanner_selection_preview %}
    <div class="sw-cms-preview-annotationBanner-selection">
        <div class="sw-cms-preview-annotation-banner-selection__image-slot">
            <img style="width:100%" :src="assetFilter('/administration/administration/static/img/cms/preview_glasses_large.jpg')" alt="google-map">

            <div class="sw-cms-preview-annotationBanner-selection_block-section-pointer-show">
                <span type="radio" class="pointer_slide-on_xy_axis point-1"></span>
                <span type="radio" class="pointer_slide-on_xy_axis point-2"></span>
                <span type="radio" class="pointer_slide-on_xy_axis point-3"></span>
            </div>
        </div>
        <div class="sw-cms-preview-annotation-banner-selection__text-slot">
            <h2>Lorem Ipsum dolor</h2>
            <p>Lorem ipsum dolor sit amet, consetetur sadipscing elitr</p>
        </div>
    </div>
{% endblock %}
