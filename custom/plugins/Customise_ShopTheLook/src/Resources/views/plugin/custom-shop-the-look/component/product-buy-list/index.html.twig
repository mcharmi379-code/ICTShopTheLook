{% if enablePrices is not defined %}
    {% set enablePrices = true %}
{% endif %}
{% if enableAddToCartAll is not defined %}
    {% set enableAddToCartAll = true %}
{% endif %}
{% if enableAddToCartSingle is not defined %}
    {% set enableAddToCartSingle = true %}
{% endif %}
{% if enableVariantSwitch is not defined %}
    {% set enableVariantSwitch = true %}
{% endif %}

{% set options = {
    enablePrices: enablePrices,
    enableAddToCartAll: enableAddToCartAll,
    enableAddToCartSingle: enableAddToCartSingle,
    enableVariantSwitch: enableVariantSwitch,
    currencyIso: context.currency.isoCode
} %}

{% if products.count > 0 %}
    <div class="custom-product-buy-list"
         data-custom-product-buy-list
         data-custom-product-buy-list-options='{{ options|json_encode|raw }}'>
        <ul class="custom-product-buy-list-items">
            {% for product in products %}

                <li class="data-custom-product-buy-list-item" data-custom-product-buy-list-item>
                    {% sw_include '@Storefront/plugin/custom-shop-the-look/component/product-buy-list/product-item.html.twig' with {
                        enableVariantSwitch:enableVariantSwitch
                    }%}
                </li>
            {% endfor %}
        </ul>

        {% if enableAddToCartAll %}
            <div class="custom-product-buy-list-form">
                <div class="mb-2">
                    <div class="text-left">
     
                        <span class="selected-items" style="display:none;">0</span>
                    </div>

                    {# {% if enablePrices %}
                        <div class="text-right">
                            {{ "moorl-foundation.general.subTotal"|trans|sw_sanitize }}:
                            <span class="total-price">{{ 0|currency }}</span>
                        </div>
                    {% endif %}#}
                </div>
                <form action="{{ path('frontend.checkout.line-item.add') }}"
                      method="post"
                      data-add-to-cart="true">
                    {{ sw_csrf('frontend.checkout.line-item.add') }}
                    <input type="hidden" name="redirectTo" value="frontend.cart.offcanvas">
                    <div class="form-values"><!-- Will be set by JavaScript --></div>
                    <button data-custom-product-buy-list-button
                            class="btn btn-primary btn-block btn-buy"
                            title="{{ "detail.addProduct"|trans|striptags }}"
                            aria-label="{{ "detail.addProduct"|trans|striptags }}">
                        {{ "detail.addProduct"|trans|striptags }}
                    </button>
                </form>
            </div>
        {% endif %}
    </div>
{% elseif emptyText %}
    {% sw_include "@Storefront/storefront/utilities/alert.html.twig" with {
        type: "primary",
        content: emptyText ?: "custom-shop-the-look.search.notAvailable"|trans
    } %}
{% endif %}
